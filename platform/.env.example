DATABASE_URL="postgresql://nims:nims_dev@localhost:5433/nims"
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=info

# Session JWT for browser sign-in (POST /v1/auth/login). Required in production.
JWT_SECRET="8729a8bf80809b2e9ef01057ee20092f281f4b0e53ade47bf9671da5436c8e8d"
# Optional; e.g. "12h", "8h"
# JWT_EXPIRES_IN="12h"

# Seed user (npm run db:seed)
# SEED_ADMIN_EMAIL="admin@demo.local"
# SEED_ADMIN_PASSWORD="ChangeMe!Admin"

# Large synthetic inventory (npm run db:seed:bulk). See nims/seed_provider_bulk.py
# PROVIDER_BULK_LITE=1
# PROVIDER_BULK_CONFIRM=yes
# PROVIDER_BULK_PURGE=1
# NUM_REGIONS=25 NUM_SITES_PER_REGION=100 RACKS_PER_SITE=2 DEVICES_PER_RACK=10

# --- Sign-in: local and at most one of LDAP, Entra, or OIDC ---
# If set, environment overrides database / Admin UI. Secrets are never sent to the browser; use
# IDENTITY_ENCRYPTION_KEY (or JWT is folded in) to encrypt at-rest IdP secrets in the DB.
# Enable email/password. Default true if unset.
# AUTH_LOCAL_ENABLED=1
# One of: none | ldap | azure_ad | oidc. Env wins; UI is read-only when this is set.
# AUTH_EXTERNAL_PROVIDER=none
# LDAP/AD
# AUTH_LDAP_URL="ldap://directory.example.com:389"
# AUTH_LDAP_BIND_DN=""
# AUTH_LDAP_BIND_PASSWORD=""
# AUTH_LDAP_USER_SEARCH_BASE="DC=example,DC=com"
# AUTH_LDAP_USER_SEARCH_FILTER="(sAMAccountName={username})"
# Microsoft Entra ID
# AUTH_AZURE_TENANT_ID=""
# AUTH_AZURE_CLIENT_ID=""
# AUTH_AZURE_CLIENT_SECRET=""
# OpenID Connect
# AUTH_OIDC_ISSUER="https://issuer.example.com"
# AUTH_OIDC_CLIENT_ID=""
# AUTH_OIDC_CLIENT_SECRET=""
# AUTH_OIDC_REDIRECT_URI="https://app.example.com/callback/oidc"
# Optional: dedicated key for identityConfig secret blobs (else JWT_SECRET is used)
# IDENTITY_ENCRYPTION_KEY="..."

# --- Async jobs: queue work to a separate process (same DATABASE_URL) ---
# JOB_EXECUTION_MODE=inline
# When set to async, POST /v1/jobs/:key/run leaves the JobRun PENDING; run: nims-worker
# JOB_EXECUTION_MODE=async
# JOB_WORKER_POLL_INTERVAL_SEC=2
# JOB_WORKER_BATCH_SIZE=5

# --- Connectors: encrypt credentials at rest (Fernet) + outbound URL policy ---
# Without CONNECTOR_SECRETS_FERNET_KEY, credentials are stored as JSON (dev only).
# CONNECTOR_SECRETS_FERNET_KEY=""
# CONNECTOR_SECRETS_FERNET_KEY_PREVIOUS=""
# Optional: document-only until wired to a cloud KMS
# CONNECTOR_SECRETS_KMS_KEY_ID=""
# CONNECTOR_URL_BLOCK_PRIVATE_NETWORKS=1
# Optional: hostname must also match a suffix (comma-separated)
# CONNECTOR_URL_ALLOWED_HOST_SUFFIXES="api.example.com"
# Production: restrict to HTTPS
# CONNECTOR_URL_HTTP_ALLOWED_SCHEMES=https
# CONNECTOR_HTTP_FOLLOW_REDIRECTS=0
