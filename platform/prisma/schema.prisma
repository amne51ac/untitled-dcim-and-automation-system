/// A slot (bay) is either on a device chassis or on an installed module (card) for nested line cards.
model ModuleBay {
  id               String   @id @default(uuid()) @db.Uuid
  deviceId         String?  @db.Uuid
  device           Device?  @relation(fields: [deviceId], references: [id])
  /// When set, this slot is on a module (card) rather than directly on the device.
  parentModuleId   String?  @db.Uuid
  parentModule     Module?  @relation("SlotsOnModule", fields: [parentModuleId], references: [id], onDelete: Cascade)
  name             String
  position         Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deletedAt        DateTime?
  /// At most one module (card) seated in this slot.
  seatedModule     Module?  @relation("CardInBay")

  @@index([deviceId])
  @@index([parentModuleId])
}

