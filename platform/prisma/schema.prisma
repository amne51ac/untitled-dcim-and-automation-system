// Network automation & DCIM — Phase 1 data model (clean-room derived)
// UUID keys, soft-delete, tenant-scoped resources

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Tenancy & identity ---

model Organization {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  slug      String   @unique
  /// Instance identity: local + IdP (LDAP, Entra, OIDC). Merged with env; env wins.
  identityConfig Json  @default("{}")
  /// LLM / Copilot: base URL, default model, encrypted API key, flags. Merged with LLM_* env; env wins.
  llmConfig     Json  @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  users    User[]
  copilotSkills CopilotSkill[]
  projects Project[]
  apiTokens ApiToken[]
  locations Location[]
  racks     Rack[]
  devices   Device[]
  vrfs      Vrf[]
  prefixes  Prefix[]
  ipAddresses IpAddress[]
  vlans     Vlan[]
  circuits  Circuit[]
  providers Provider[]
  jobs      JobDefinition[]
  jobRuns   JobRun[]
  webhooks  WebhookSubscription[]
  auditEvents AuditEvent[]
  observedStates ObservedResourceState[]
  serviceInstances ServiceInstance[]
  changeRequests ChangeRequest[]
  objectTemplates   ObjectTemplate[]
  resourceExtensions ResourceExtension[]
  dynamicGroups              DynamicGroup[]
  virtualChassis             VirtualChassis[]
  controllers                Controller[]
  deviceRedundancyGroups     DeviceRedundancyGroup[]
  interfaceRedundancyGroups  InterfaceRedundancyGroup[]
  powerPanels                PowerPanel[]
  powerFeeds                 PowerFeed[]
  cloudNetworks              CloudNetwork[]
  cloudServices              CloudService[]
  wirelessNetworks           WirelessNetwork[]
  vpns                       Vpn[]
  clusters                   Cluster[]
  virtualMachines            VirtualMachine[]
  mplsDomains                MplsDomain[]
  tags                       Tag[]
  routeTargets               RouteTarget[]
  providerNetworks           ProviderNetwork[]
  rackGroups                 RackGroup[]
  circuitDiversityGroups     CircuitDiversityGroup[]
  rackReservations           RackReservation[]
  pluginPlacements           PluginPlacement[]
  tenantGroups               TenantGroup[]
  contacts                   Contact[]
  teams                      Team[]
  ipamNamespaces             IpamNamespace[]
  virtualDeviceContexts      VirtualDeviceContext[]
  deviceGroups               DeviceGroup[]
  pluginRegistrations         PluginRegistration[]
  connectorRegistrations     ConnectorRegistration[]
  modules                    Module[]
  inventoryItems             InventoryItem[]
  softwareImageFiles         SoftwareImageFile[]
  consoleConnections         ConsoleConnection[]
  powerConnections           PowerConnection[]
  circuitTerminations        CircuitTermination[]
  rackElevations             RackElevation[]
  statusDefinitions          StatusDefinition[]
}

model Project {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String  @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  slug           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, slug])
  @@index([organizationId])
}

enum ApiTokenRole {
  READ
  WRITE
  ADMIN
}

enum UserAuthProvider {
  LOCAL
  LDAP
  AZURE_AD
  OIDC
}

/// Interactive sign-in (password, LDAP, OIDC). API automation continues to use ApiToken.
model User {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  email          String
  displayName    String?
  /// bcrypt hash; null when the account is SSO-only (no local password).
  passwordHash   String?
  role           ApiTokenRole @default(READ)
  authProvider   UserAuthProvider @default(LOCAL)
  /// External subject (e.g. OIDC `sub`, LDAP bind DN) for IdP matching.
  externalSubject String?
  /// UI prefs: pinned pages, etc. `{ "pinnedPages": [ { "path": "/dcim/devices", "label": "Devices" } ] }`
  preferences    Json     @default("{}")
  /// When false, interactive sign-in is blocked (org admins can reactivate).
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  copilotSkills CopilotSkill[]

  @@unique([organizationId, email])
  @@index([organizationId])
}

/// Saved Copilot prompt templates; visibility PRIVATE (owner) or ORG (library).
enum CopilotSkillVisibility {
  PRIVATE
  ORG
}

model CopilotSkill {
  id              String   @id @default(uuid()) @db.Uuid
  organizationId  String   @db.Uuid
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  userId          String   @db.Uuid
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title           String
  description     String?
  /// User message template; may include {{id}}, {{resourceType}}, etc.
  body            String
  visibility      CopilotSkillVisibility @default(PRIVATE)
  /// Empty = any page; e.g. ["Device","Rack"]
  applicableResourceTypes String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([organizationId])
  @@index([userId])
}

model ApiToken {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  tokenHash      String   @unique
  role           ApiTokenRole @default(WRITE)
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  lastUsedAt     DateTime?

  @@index([organizationId])
}

// --- DCIM ---

model LocationType {
  id          String     @id @default(uuid()) @db.Uuid
  name        String     @unique
  description String?
  locations   Location[]
}

model Location {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  parentId       String?  @db.Uuid
  parent         Location? @relation("LocationHierarchy", fields: [parentId], references: [id])
  children       Location[] @relation("LocationHierarchy")
  locationTypeId String   @db.Uuid
  locationType   LocationType @relation(fields: [locationTypeId], references: [id])
  name           String
  slug           String
  description    String?
  latitude       Float?
  longitude      Float?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  racks Rack[]
  powerPanels PowerPanel[]
  circuitTerminations CircuitTermination[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@index([parentId])
}

model Rack {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  locationId     String   @db.Uuid
  location       Location @relation(fields: [locationId], references: [id])
  name           String
  uHeight        Int      @default(42)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  devices Device[]
  rackGroupId String?   @db.Uuid
  rackGroup   RackGroup? @relation(fields: [rackGroupId], references: [id])
  reservations RackReservation[]
  elevations  RackElevation[]

  @@unique([organizationId, locationId, name])
  @@index([organizationId])
  @@index([rackGroupId])
}

model Manufacturer {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  deviceTypes DeviceType[]
  deviceFamilies DeviceFamily[]
  moduleTypes    ModuleType[]
}

model DeviceType {
  id             String @id @default(uuid()) @db.Uuid
  manufacturerId String @db.Uuid
  manufacturer   Manufacturer @relation(fields: [manufacturerId], references: [id])
  model          String
  uHeight        Int    @default(1)
  devices        Device[]

  @@unique([manufacturerId, model])
}

model DeviceRole {
  id      String   @id @default(uuid()) @db.Uuid
  name    String   @unique
  devices Device[]
}

enum DeviceStatus {
  PLANNED
  STAGED
  ACTIVE
  DECOMMISSIONED
}

model Device {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  rackId         String?  @db.Uuid
  rack           Rack?    @relation(fields: [rackId], references: [id])
  deviceTypeId   String   @db.Uuid
  deviceType     DeviceType @relation(fields: [deviceTypeId], references: [id])
  deviceRoleId   String   @db.Uuid
  deviceRole     DeviceRole @relation(fields: [deviceRoleId], references: [id])
  name           String
  serialNumber   String?
  positionU      Int?
  face           String?  // front | rear
  status         DeviceStatus @default(PLANNED)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  interfaces Interface[]
  observed   ObservedResourceState?
  virtualChassisMemberships VirtualChassisMember[]
  controllers               Controller[]
  deviceRedundancyMemberships DeviceRedundancyGroupMember[]
  frontPorts                  FrontPort[]
  rearPorts                   RearPort[]
  consolePorts                ConsolePort[]
  consoleServerPorts          ConsoleServerPort[]
  powerPorts                  PowerPort[]
  powerOutlets                PowerOutlet[]
  deviceBaysAsParent          DeviceBay[] @relation("DeviceBayParent")
  deviceBaysAsChild           DeviceBay[] @relation("DeviceBayChild")
  moduleBays                  ModuleBay[]
  modules                     Module[]
  virtualDeviceContexts       VirtualDeviceContext[]
  deviceGroupMemberships      DeviceGroupMember[]
  inventoryItems              InventoryItem[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([rackId])
}

model Interface {
  id        String   @id @default(uuid()) @db.Uuid
  deviceId  String   @db.Uuid
  device    Device   @relation(fields: [deviceId], references: [id])
  name      String
  type      String   // ethernet, loopback, etc.
  macAddress String?
  mtu       Int?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  ipAddresses IpAddress[]
  cableEndsA  Cable[] @relation("CableA")
  cableEndsB  Cable[] @relation("CableB")
  interfaceRedundancyMemberships InterfaceRedundancyGroupMember[]

  @@unique([deviceId, name])
  @@index([deviceId])
}

model Cable {
  id        String   @id @default(uuid()) @db.Uuid
  interfaceAId String @db.Uuid
  interfaceA   Interface @relation("CableA", fields: [interfaceAId], references: [id])
  interfaceBId String @db.Uuid
  interfaceB   Interface @relation("CableB", fields: [interfaceBId], references: [id])
  label     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([interfaceAId])
  @@index([interfaceBId])
}

// --- IPAM ---

model Vrf {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  rd             String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  prefixes      Prefix[]
  routeTargets  RouteTarget[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Prefix {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  vrfId          String   @db.Uuid
  vrf            Vrf      @relation(fields: [vrfId], references: [id])
  cidr           String
  description    String?
  parentId       String?  @db.Uuid
  parent         Prefix?  @relation("PrefixHierarchy", fields: [parentId], references: [id])
  children       Prefix[] @relation("PrefixHierarchy")
  rirId          String?  @db.Uuid
  rir            Rir?     @relation(fields: [rirId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  ipAddresses IpAddress[]

  @@unique([organizationId, vrfId, cidr])
  @@index([organizationId])
}

model IpAddress {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  prefixId       String   @db.Uuid
  prefix         Prefix   @relation(fields: [prefixId], references: [id])
  address        String
  description    String?
  interfaceId    String?  @db.Uuid
  interface      Interface? @relation(fields: [interfaceId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, address])
  @@index([prefixId])
}

model VlanGroup {
  id    String @id @default(uuid()) @db.Uuid
  name  String @unique
  vlans Vlan[]
}

model Vlan {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  vlanGroupId    String?  @db.Uuid
  vlanGroup      VlanGroup? @relation(fields: [vlanGroupId], references: [id])
  vid            Int
  name           String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, vid])
  @@index([organizationId])
}

// --- Circuits ---

model Provider {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  asn            Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  circuits         Circuit[]
  circuitSegments  CircuitSegment[]
  providerNetworks ProviderNetwork[]

  @@unique([organizationId, name])
  @@index([organizationId])
}

enum CircuitStatus {
  PLANNED
  ACTIVE
  DECOMMISSIONED
}

model Circuit {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  providerId     String   @db.Uuid
  provider       Provider @relation(fields: [providerId], references: [id])
  circuitTypeId  String?  @db.Uuid
  circuitType    CircuitType? @relation(fields: [circuitTypeId], references: [id])
  circuitDiversityGroupId String?  @db.Uuid
  circuitDiversityGroup   CircuitDiversityGroup? @relation(fields: [circuitDiversityGroupId], references: [id], onDelete: SetNull)
  cid            String
  bandwidthMbps  Int?
  status         CircuitStatus @default(PLANNED)
  aSideNotes     String?
  zSideNotes     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  segments      CircuitSegment[]
  terminations  CircuitTermination[]

  @@unique([organizationId, cid])
  @@index([organizationId])
  @@index([circuitTypeId])
  @@index([circuitDiversityGroupId])
}

/// Circuits that share fate for diversity planning (e.g. parallel paths that must not share conduit).
model CircuitDiversityGroup {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  slug           String
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  circuits Circuit[]

  @@unique([organizationId, slug])
  @@index([organizationId])
}

/// Ordered leg of a multi-carrier or multi-hop circuit; inherits provider when providerId is null.
model CircuitSegment {
  id             String   @id @default(uuid()) @db.Uuid
  circuitId      String   @db.Uuid
  circuit        Circuit  @relation(fields: [circuitId], references: [id], onDelete: Cascade)
  segmentIndex   Int
  label          String?
  providerId     String?  @db.Uuid
  provider       Provider? @relation(fields: [providerId], references: [id])
  bandwidthMbps  Int?
  status         CircuitStatus @default(PLANNED)
  aSideNotes     String?
  zSideNotes     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([circuitId, segmentIndex])
  @@index([circuitId])
}

// --- AS1-style: service inventory + closed-loop observed state ---

model ServiceInstance {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  serviceType    String
  customerRef    String?
  status         String   @default("active")
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@index([organizationId])
}

enum ObservationKind {
  DEVICE
  INTERFACE
  SERVICE
}

// Reconciliation: last observed telemetry vs intent (drift flag)
model ObservedResourceState {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  kind           ObservationKind
  deviceId       String?  @unique @db.Uuid
  device         Device?  @relation(fields: [deviceId], references: [id])
  lastSeenAt     DateTime?
  health         String?
  payload        Json?
  driftDetected  Boolean  @default(false)
  driftSummary   String?
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([kind])
}

// --- Automation: jobs, approvals, change requests ---

enum JobRunStatus {
  PENDING
  APPROVAL_REQUIRED
  APPROVED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

model JobDefinition {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  key            String
  name           String
  description    String?
  requiresApproval Boolean @default(false)
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  runs JobRun[]

  @@unique([organizationId, key])
  @@index([organizationId])
}

model JobRun {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  jobDefinitionId String  @db.Uuid
  jobDefinition  JobDefinition @relation(fields: [jobDefinitionId], references: [id])
  status         JobRunStatus @default(PENDING)
  idempotencyKey String?
  input          Json?
  output         Json?
  logs           String?
  correlationId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([jobDefinitionId])
  @@index([idempotencyKey])
}

enum ChangeRequestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  APPLIED
}

model ChangeRequest {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  title          String
  description    String?
  payload        Json
  status         ChangeRequestStatus @default(DRAFT)
  correlationId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

// --- Events & webhooks ---

enum WebhookEvent {
  CREATE
  UPDATE
  DELETE
}

model WebhookSubscription {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  url            String
  secret         String?
  resourceTypes  String[]
  events         WebhookEvent[]
  enabled        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
}

model AuditEvent {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  actor          String
  action         String
  resourceType   String
  resourceId     String
  correlationId  String?
  before         Json?
  after          Json?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([resourceType, resourceId])
  @@index([correlationId])
}

// --- Object templates & custom attributes (per-tenant) ---

/// Form schema + custom fields for a resource type. `definition` JSON: { "version": 1, "fields": [...] }.
model ObjectTemplate {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  resourceType   String
  name           String
  slug           String
  description    String?
  isSystem       Boolean  @default(false)
  isDefault      Boolean  @default(false)
  definition     Json
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  resourceExtensions ResourceExtension[]

  @@unique([organizationId, resourceType, slug])
  @@index([organizationId, resourceType])
}

/// Key/value bag for non-column custom attributes; one row per resource instance.
model ResourceExtension {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  resourceType   String
  resourceId     String   @db.Uuid
  templateId     String?  @db.Uuid
  template       ObjectTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  data           Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, resourceType, resourceId])
  @@index([organizationId])
}

// --- Extended inventory (Phase 2): org-scoped catalog objects ---

/// Saved filter / membership rules (NetBox-style dynamic groups).
model DynamicGroup {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  slug           String
  description    String?
  definition     Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model VirtualChassis {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  domainId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  members VirtualChassisMember[]

  @@index([organizationId])
}

model VirtualChassisMember {
  id                 String   @id @default(uuid()) @db.Uuid
  virtualChassisId   String   @db.Uuid
  virtualChassis     VirtualChassis @relation(fields: [virtualChassisId], references: [id], onDelete: Cascade)
  deviceId           String   @db.Uuid
  device             Device   @relation(fields: [deviceId], references: [id])
  priority           Int      @default(0)

  @@unique([virtualChassisId, deviceId])
  @@index([deviceId])
}

model Controller {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  description    String?
  /// Optional: device this controller manages (BMC / automation target).
  deviceId       String?  @db.Uuid
  device         Device?  @relation(fields: [deviceId], references: [id])
  role           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@index([organizationId])
  @@index([deviceId])
}

model DeviceRedundancyGroup {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  protocol       String?
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  members DeviceRedundancyGroupMember[]

  @@index([organizationId])
}

model DeviceRedundancyGroupMember {
  id        String   @id @default(uuid()) @db.Uuid
  groupId   String   @db.Uuid
  group     DeviceRedundancyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  deviceId  String   @db.Uuid
  device    Device   @relation(fields: [deviceId], references: [id])
  role      String?

  @@unique([groupId, deviceId])
  @@index([deviceId])
}

model InterfaceRedundancyGroup {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  protocol       String?
  description    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  members InterfaceRedundancyGroupMember[]

  @@index([organizationId])
}

model InterfaceRedundancyGroupMember {
  id          String   @id @default(uuid()) @db.Uuid
  groupId     String   @db.Uuid
  group       InterfaceRedundancyGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  interfaceId String   @db.Uuid
  interface   Interface @relation(fields: [interfaceId], references: [id])
  role        String?

  @@unique([groupId, interfaceId])
  @@index([interfaceId])
}

model PowerPanel {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id])
  locationId     String   @db.Uuid
